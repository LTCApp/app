  "notifications": {
    "sound": {
      "enabled": true,
      "volume": 0.7,
      "types": {
        "newOrder": {
          "frequency": 800,
          "duration": 0.5,
          "repeat": 1
        },
        "urgent": {
          "frequency": 1000,
          "duration": 0.3,
          "repeat": 3
        },
        "complete": {
          "frequency": 600,
          "duration": 0.4,
          "repeat": 1
        },
        "error": {
          "frequency": 400,
          "duration": 0.6,
          "repeat": 2
        }
      }
    },
    
    "visual": {
      "enabled": true,
      "duration": 5000,
      "animations": true,
      "colors": {
        "info": "#3498db",
        "success": "#27ae60",
        "warning": "#f39c12",
        "error": "#e74c3c"
      }
    },
    
    "vibration": {
      "enabled": true,
      "patterns": {
        "newOrder": [200, 100, 200],
        "urgent": [400, 200, 400, 200, 400],
        "complete": [300],
        "error": [500, 300, 500]
      }
    }
  },
  
  "performance": {
    "autoRefresh": {
      "enabled": true,
      "interval": 30000,
      "backgroundOnly": false
    },
    
    "caching": {
      "enabled": true,
      "maxAge": 300000,
      "strategies": ["memory", "localStorage", "indexedDB"]
    },
    
    "optimization": {
      "lazyLoading": true,
      "imageCompression": true,
      "gzipCompression": true,
      "minification": true
    },
    
    "limits": {
      "maxOrders": 1000,
      "maxLogs": 100,
      "maxNotifications": 50,
      "sessionTimeout": 43200000
    }
  },
  
  "ai": {
    "enabled": true,
    "features": {
      "demandPrediction": true,
      "optimizeScheduling": true,
      "qualityAnalysis": true,
      "costOptimization": true,
      "staffOptimization": true
    },
    
    "settings": {
      "learningRate": 0.01,
      "analysisInterval": 3600000,
      "predictionHorizon": 86400000,
      "confidenceThreshold": 0.8
    }
  },
  
  "analytics": {
    "realtime": {
      "enabled": true,
      "updateInterval": 5000,
      "metrics": [
        "activeOrders",
        "completionRate",
        "averageTime",
        "efficiency",
        "customerSatisfaction"
      ]
    },
    
    "historical": {
      "enabled": true,
      "retentionDays": 365,
      "aggregation": ["hourly", "daily", "weekly", "monthly"],
      "export": ["json", "csv", "pdf"]
    },
    
    "predictive": {
      "enabled": true,
      "algorithms": ["linear", "polynomial", "neural"],
      "accuracy": 0.85,
      "horizon": ["1h", "4h", "24h", "7d"]
    }
  },
  
  "security": {
    "authentication": {
      "method": "password",
      "minPasswordLength": 6,
      "sessionTimeout": 43200000,
      "maxFailedAttempts": 3,
      "lockoutDuration": 900000
    },
    
    "encryption": {
      "enabled": true,
      "algorithm": "AES-256",
      "keyRotation": 2592000000
    },
    
    "audit": {
      "enabled": true,
      "logActions": true,
      "retentionDays": 90,
      "alertOnSuspicious": true
    }
  },
  
  "integration": {
    "pos": {
      "enabled": true,
      "protocol": "REST",
      "endpoint": "/api/pos",
      "syncInterval": 10000
    },
    
    "inventory": {
      "enabled": true,
      "autoUpdate": true,
      "thresholds": {
        "low": 10,
        "critical": 5,
        "reorder": 20
      }
    },
    
    "delivery": {
      "enabled": true,
      "providers": ["internal", "external"],
      "tracking": true,
      "notifications": true
    }
  },
  
  "localization": {
    "defaultLanguage": "ar",
    "supportedLanguages": ["ar", "en", "fr"],
    "dateFormat": "DD/MM/YYYY",
    "timeFormat": "HH:mm:ss",
    "currency": "SAR",
    "timezone": "Asia/Riyadh"
  },
  
  "ui": {
    "theme": "dark",
    "animations": {
      "enabled": true,
      "duration": 300,
      "easing": "ease-in-out"
    },
    
    "layout": {
      "sidebarWidth": 280,
      "headerHeight": 80,
      "cardSpacing": 20,
      "borderRadius": 15
    },
    
    "accessibility": {
      "highContrast": false,
      "largeText": false,
      "screenReader": true,
      "keyboardNavigation": true
    }
  },
  
  "monitoring": {
    "health": {
      "enabled": true,
      "checkInterval": 60000,
      "endpoints": [
        "/health",
        "/api/status",
        "/database/ping"
      ]
    },
    
    "performance": {
      "enabled": true,
      "metrics": [
        "responseTime",
        "throughput",
        "errorRate",
        "resourceUsage"
      ],
      "alertThresholds": {
        "responseTime": 1000,
        "errorRate": 0.05,
        "cpuUsage": 0.8,
        "memoryUsage": 0.9
      }
    },
    
    "logging": {
      "level": "info",
      "outputs": ["console", "file", "remote"],
      "rotation": {
        "enabled": true,
        "maxSize": "10MB",
        "maxFiles": 5
      }
    }
  },
  
  "backup": {
    "enabled": true,
    "schedule": "0 2 * * *",
    "retention": {
      "daily": 7,
      "weekly": 4,
      "monthly": 12
    },
    "storage": {
      "local": true,
      "cloud": false,
      "encryption": true
    }
  },
  
  "compliance": {
    "standards": [
      "ISO-22000",
      "HACCP",
      "FDA",
      "SFDA"
    ],
    "auditing": {
      "enabled": true,
      "frequency": "monthly",
      "autoGenerate": true
